---
// src/components/SurvivalTable.astro
// 1. 讓這個小零件自己去讀取 JSON
import survivalData from '../data/survival_data.json';
---

<div class="my-8 rounded-xl border border-gray-200 shadow-sm bg-white max-h-[500px] overflow-auto">
  <table class="min-w-full text-sm text-center whitespace-nowrap">
    <thead class="bg-gray-50 sticky top-0 z-10 shadow-sm">
      <tr>
        <th class="px-4 py-3 font-bold text-gray-900">樣本 ID</th>
        <th class="px-4 py-3 font-bold text-gray-900">真實存活 (天)</th>
        <th class="px-4 py-3 font-bold text-blue-600 bg-blue-50/50">初始模型預測</th>
        <th class="px-4 py-3 font-bold text-green-600 bg-green-50/50">修正模型預測</th>
        <th class="px-4 py-3 font-bold text-rose-600 bg-rose-50/50">簡化模型預測</th>
        <th class="px-4 py-3 font-bold text-blue-600 bg-blue-50/50">初始模型誤差</th>
        <th class="px-4 py-3 font-bold text-green-600 bg-green-50/50">修正模型誤差</th>
        <th class="px-4 py-3 font-bold text-rose-600 bg-rose-50/50">簡化模型誤差</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100 font-mono">
      {survivalData.map((row) => (
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-4 py-3 text-gray-400">{row.ID}</td>
          <td class="px-4 py-3 font-bold text-gray-800">{row.真實存活時間_天}</td>
          <td class="px-4 py-3 font-bold text-blue-500 bg-blue-50/10">{row.初始模型預測}</td>
          <td class="px-4 py-3 font-bold text-green-500 bg-green-50/10">{row.修正模型預測}</td>
          <td class="px-4 py-3 font-bold text-rose-500 bg-rose-50/10">{row.簡化模型預測}</td>
          <td class="px-4 py-3 font-bold text-blue-500 bg-blue-50/10">{row.初始模型誤差}</td>
          <td class="px-4 py-3 font-bold text-green-500 bg-green-50/10">{row.修正模型誤差}</td>
          <td class="px-4 py-3 font-bold text-rose-500 bg-rose-50/10">{row.簡化模型誤差}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>